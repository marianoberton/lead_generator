# === API Keys — comma-separated para rotación automática ===

# Apollo.io (50 emails/mes por key en plan free)
APOLLO_API_KEYS=key1,key2,key3

# Google Places API v1 ($200 crédito gratis/mes por key ≈ 6250 búsquedas)
GOOGLE_PLACES_API_KEYS=key1,key2

# Hunter.io (25 búsquedas de dominio/mes por key en plan free)
HUNTER_API_KEYS=key1,key2,key3,key4

# === Keys únicas (retrocompatibilidad, opcional) ===
APOLLO_API_KEY=
GOOGLE_PLACES_API_KEY=
HUNTER_API_KEY=

# === Configuración opcional ===
CRAWL_CONCURRENCY=20
HUNTER_MIN_SCORE=40
