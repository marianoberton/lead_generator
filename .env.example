# ============================================================
#  FOMO Lead Generation — Variables de entorno
# ============================================================
#  Copiar este archivo como .env y completar con tus keys.
#  Las keys tambien se pueden cargar desde la web app en /keys.
# ============================================================

# ── Fuentes de leads ─────────────────────────────────────────

# Apollo.io — 50 leads/mes gratis
# Registrarse en apollo.io → Settings → API Keys
APOLLO_API_KEY=

# Apify — $5 credito gratis por cuenta (scraping Google Maps)
# Registrarse en apify.com → Settings → Integrations → API tokens
APIFY_API_KEY=

# Google Places API — requiere billing activado ($200 credito gratis/mes)
# Opcional: si no hay, usar Apify como alternativa gratuita
GOOGLE_PLACES_API_KEY=

# ── Servicios de enrichment (busqueda de emails) ────────────

# Hunter.io — 25 busquedas/mes gratis por cuenta
# Registrarse en hunter.io → Dashboard → API → copiar key
HUNTER_API_KEY=

# Skrapp.io — 100 busquedas/mes gratis por cuenta (mejor free tier)
# Registrarse en skrapp.io → Settings → API → copiar token
SKRAPP_API_KEY=

# Snov.io — 50 busquedas/mes gratis por cuenta
# Registrarse en snov.io → Integrations → API → Client ID + Secret
# Formato: client_id:client_secret
SNOV_API_KEY=

# Tomba.io — 25 busquedas/mes gratis por cuenta
# Registrarse en tomba.io → Settings → API Keys → Key + Secret
# Formato: api_key:api_secret
TOMBA_API_KEY=

# VoilaNorbert — 50 creditos gratis por cuenta (unico, no se renueva)
# Registrarse en voilanorbert.com → Settings → API → copiar token
NORBERT_API_KEY=

# ── Multiples cuentas ───────────────────────────────────────
# Para multiplicar los free tiers, registrarse con distintos emails
# y agregar las keys separadas por coma:
#
# SKRAPP_API_KEYS=key_cuenta1,key_cuenta2,key_cuenta3
# HUNTER_API_KEYS=key1,key2,key3
# SNOV_API_KEYS=id1:secret1,id2:secret2
# TOMBA_API_KEYS=key1:secret1,key2:secret2
# APIFY_API_KEYS=token1,token2,token3
#
# O cargarlas una por una desde la web app en /keys (recomendado).

# ── Configuracion ───────────────────────────────────────────

# Puerto de la web app (default: 8000)
PORT=8001

# Concurrencia del crawler (default: 20)
CRAWL_CONCURRENCY=20

# Score minimo de Hunter para aceptar un email (default: 40)
HUNTER_MIN_SCORE=40
